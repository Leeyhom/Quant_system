# ============================================================
# 量化策略实时服务 - 配置文件
# 复制此文件到 .env 并填入真实配置
# ============================================================

# 服务端口
PORT=8080
HOST=0.0.0.0

# 飞书通知配置
# 飞书机器人Webhook地址
FEISHU_WEBHOOK_URL=
# 是否开启飞书通知 (1=开启 0=关闭)
FEISHU_NOTIFY=0

# OpenClaw 配置（如使用）
OPENCLAW_ENDPOINT=http://localhost:8000
OPENCLAW_API_KEY=

# 数据源配置
# 可选: tushare / akshare / yahoo
DATA_SOURCE=akshare

# 模拟盘 / 实盘 配置
# PAPER / LIVE
TRADING_MODE=PAPER

# 券商API配置（如使用）
BROKER_TYPE=
BROKER_API_KEY=
BROKER_SECRET=

# 风险控制
MAX_DRAWDOWN_PER_STOCK=0.15
MAX_POSITION_WEIGHT=0.10
TOTAL_POSITION_LIMIT=0.95
DAILY_LOSS_LIMIT=0.05
